  token: {{token}}
}

body:json {
  {
    "title": "MOU with ABC Innovations",
    "partner_organization": "ABC Innovations",
    "signatory_internal": "Dean, Faculty of Engineering",
    "signatory_external": "CEO, ABC Innovations",
    "status": "pending_signature"
  }
}
